<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
 "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.bot7.market-collector</string>
    <key>ProgramArguments</key>
    <array>
        <string>/usr/bin/caffeinate</string>
        <string>-i</string>
        <string>%BOT7_PATH%/.venv/bin/python</string>
        <string>-m</string>
        <string>market_collector.collector</string>
    </array>
    <key>WorkingDirectory</key>
    <string>%BOT7_PATH%</string>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>ThrottleInterval</key>
    <integer>30</integer>
    <key>StandardOutPath</key>
    <string>%BOT7_PATH%/logs/launchd_collector.log</string>
    <key>StandardErrorPath</key>
    <string>%BOT7_PATH%/logs/launchd_collector.err</string>
    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/usr/local/bin:/usr/bin:/bin:%BOT7_PATH%/.venv/bin</string>
        <key>PYTHONUNBUFFERED</key>
        <string>1</string>
    </dict>
</dict>
</plist>
