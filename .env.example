# bot7 — environment template
# Copy to .env.local and fill in real values. .env.local is gitignored.
# Sections roughly mirror the responsible service.

# ─── Telegram bot (required) ────────────────────────────────────────────────
# PROD машина: BOT_TOKEN = реальный @bot7_main_bot токен
# DEV машина (Win параллельно с Mac-prod): отдельный @bot7_dev_bot токен —
#   создать через @BotFather, отправлять в тестовый чат, не дублировать prod.
# См. docs/MAC_NIGHT_MIRROR.md для разделения prod/dev по машинам.
BOT_TOKEN=PUT_YOUR_TG_BOT_TOKEN_HERE
# Comma-separated chat IDs allowed to interact with the bot.
# PRIMARY chat — все critical/important/info сообщения (alerts, setups, P-15 OPEN/CLOSE)
ALLOWED_CHAT_IDS=
# ROUTINE chat — низкий приоритет: P-15 REENTRY/HARVEST, LEVEL_BREAK, paper-trade confirmations.
# Если не задан — fallback в ALLOWED_CHAT_IDS (поведение как раньше).
# Чтобы развести каналы: создать второй TG-чат, добавить туда того же бота,
# узнать chat_id (например через @userinfobot) и прописать сюда.
ROUTINE_CHAT_IDS=
ENABLE_TELEGRAM=1

# ─── Anthropic / Claude (optional — for regime_narrator and claude_bot) ─────
ANTHROPIC_API_KEY=
# Override default model used by claude_bot (services/claude_bot/bot.py)
CLAUDE_BOT_MODEL=
CLAUDE_BOT_MAX_TOKENS=
# Restrict claude_bot replies to a specific chat (comma-separated allowed)
CLAUDE_BOT_ALLOWED_CHAT_ID=

# ─── BitMEX read-only API (for auto-margin polling) ─────────────────────────
# Required if you run services/bitmex_account/poller. Read-only key is enough.
BITMEX_API_KEY=
BITMEX_API_SECRET=

# ─── Ginarea grid tracker (used by ginarea_tracker/) ────────────────────────
# GinArea: использовать ТОЛЬКО на одной машине одновременно. Если у тебя
# две машины (prod + dev) — пустые значения на dev машине отключают
# ginarea_tracker и cliff_monitor. См. docs/MAC_NIGHT_MIRROR.md.
GINAREA_API_URL=
GINAREA_EMAIL=
GINAREA_PASSWORD=
GINAREA_TOTP_SECRET=

# ─── Coinglass (optional — auxiliary data in analysis_service) ──────────────
COINGLASS_API_KEY=

# ─── ADVISOR v2 (P-15 sizing, paper trader) ─────────────────────────────────
# Operator's total deposit USD. Used to compute % allocations.
# Update when wallet deposit changes by ≥$500.
ADVISOR_DEPO_TOTAL=

# ─── GC shadow mode (research mode for grid_coordinator confirmation) ──────
# Set GC_SHADOW_MODE=1 to record GC alignment decisions into audit WITHOUT
# applying them (no hard-block, no confidence delta). Use to collect a
# week of "would have done" data before committing to a config change.
# GC backtest on 29d (limited by Binance public API) showed weak mean-revert
# edge — switching to shadow mode lets us validate per-pair before stripping
# the production penalty / hard-block.
GC_SHADOW_MODE=0

# ─── Setup detector kill switch ─────────────────────────────────────────────
# Comma-separated list of detector function names (or substrings) to disable
# without restarting. Loose match: "multi_divergence" disables
# detect_long_multi_divergence. Cache TTL 60s — picks up changes on next tick.
# Example: DISABLED_DETECTORS=h10,multi_divergence
DISABLED_DETECTORS=

# ─── Cascade alerts ─────────────────────────────────────────────────────────
# Set to "1" to auto-open paper positions on cascade alerts. Default off.
CASCADE_AUTO_OPEN=0

# ─── Telegram regulation filter ─────────────────────────────────────────────
TELEGRAM_REGULATION_FILTER_ENABLED=1
TELEGRAM_FILTER_CRITICAL_LEVELS_USD=
TELEGRAM_FILTER_CRITICAL_PROXIMITY_USD=

# ─── Telegram dedup gates (toggle individual layers) ────────────────────────
# 1 = enabled, 0 = disabled. All default 1.
DEDUP_LAYER_ENABLED_FOR_POSITION_CHANGE=1
DEDUP_LAYER_ENABLED_FOR_PNL=1
DEDUP_LAYER_ENABLED_FOR_LEVEL=1
DEDUP_LAYER_ENABLED_FOR_REGIME=1

# ─── Other (legacy / experimental) ──────────────────────────────────────────
ENABLE_ML=1
LOOP_SECONDS=120
AUTO_EDGE_ALERTS_ENABLED=true
AUTO_EDGE_ALERTS_INTERVAL_SEC=45
AUTO_EDGE_ALERTS_COOLDOWN_SEC=300
AUTO_EDGE_ALERTS_TIMEFRAMES=15m,1h
