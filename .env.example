# bot7 — environment template
# Copy to .env.local and fill in real values. .env.local is gitignored.
# Sections roughly mirror the responsible service.

# ─── Telegram bot (required) ────────────────────────────────────────────────
BOT_TOKEN=PUT_YOUR_TG_BOT_TOKEN_HERE
# Comma-separated chat IDs allowed to interact with the bot
ALLOWED_CHAT_IDS=
ENABLE_TELEGRAM=1

# ─── Anthropic / Claude (optional — for regime_narrator and claude_bot) ─────
ANTHROPIC_API_KEY=
# Override default model used by claude_bot (services/claude_bot/bot.py)
CLAUDE_BOT_MODEL=
CLAUDE_BOT_MAX_TOKENS=
# Restrict claude_bot replies to a specific chat (comma-separated allowed)
CLAUDE_BOT_ALLOWED_CHAT_ID=

# ─── BitMEX read-only API (for auto-margin polling) ─────────────────────────
# Required if you run services/bitmex_account/poller. Read-only key is enough.
BITMEX_API_KEY=
BITMEX_API_SECRET=

# ─── Ginarea grid tracker (used by ginarea_tracker/) ────────────────────────
GINAREA_API_URL=
GINAREA_EMAIL=
GINAREA_PASSWORD=
GINAREA_TOTP_SECRET=

# ─── Coinglass (optional — auxiliary data in analysis_service) ──────────────
COINGLASS_API_KEY=

# ─── ADVISOR v2 (P-15 sizing, paper trader) ─────────────────────────────────
# Operator's total deposit USD. Used to compute % allocations.
# Update when wallet deposit changes by ≥$500.
ADVISOR_DEPO_TOTAL=

# ─── Cascade alerts ─────────────────────────────────────────────────────────
# Set to "1" to auto-open paper positions on cascade alerts. Default off.
CASCADE_AUTO_OPEN=0

# ─── Telegram regulation filter ─────────────────────────────────────────────
TELEGRAM_REGULATION_FILTER_ENABLED=1
TELEGRAM_FILTER_CRITICAL_LEVELS_USD=
TELEGRAM_FILTER_CRITICAL_PROXIMITY_USD=

# ─── Telegram dedup gates (toggle individual layers) ────────────────────────
# 1 = enabled, 0 = disabled. All default 1.
DEDUP_LAYER_ENABLED_FOR_POSITION_CHANGE=1
DEDUP_LAYER_ENABLED_FOR_PNL=1
DEDUP_LAYER_ENABLED_FOR_LEVEL=1
DEDUP_LAYER_ENABLED_FOR_REGIME=1

# ─── Other (legacy / experimental) ──────────────────────────────────────────
ENABLE_ML=1
LOOP_SECONDS=120
AUTO_EDGE_ALERTS_ENABLED=true
AUTO_EDGE_ALERTS_INTERVAL_SEC=45
AUTO_EDGE_ALERTS_COOLDOWN_SEC=300
AUTO_EDGE_ALERTS_TIMEFRAMES=15m,1h
