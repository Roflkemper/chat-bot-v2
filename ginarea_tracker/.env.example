GINAREA_API_URL=https://api.ginarea.io
GINAREA_EMAIL=your_email@example.com
GINAREA_PASSWORD=your_password
GINAREA_TOTP_SECRET=BASE32SECRETFROMGOOGLEAUTH

SNAPSHOT_INTERVAL_SEC=60
OUTPUT_DIR=ginarea_live

# true = track all bots; false = use BOT_FILTER
TRACK_ALL_BOTS=true

# comma-separated bot IDs or names, used when TRACK_ALL_BOTS=false
BOT_FILTER=
