+def action_launch_liquidity_harvester(snapshot: Snapshot, params: dict) -> Snapshot:
+    """Launch temporary liquidity-harvester zone(s) around current price."""
+    side = str(params["side"])
+    if side not in {"long", "short", "both"}:
+        raise ValueError(f"side must be long/short/both, got {side}")
+    offset_pct = float(params["offset_pct"])
+    width_pct = float(params["width_pct"])
+    size_btc = float(params["size_btc"])
+    ttl_min = int(params["ttl_min"])
+    if offset_pct <= 0 or width_pct <= 0:
+        raise ValueError("offset_pct and width_pct must be > 0")
+    if size_btc <= 0:
+        raise ValueError(f"size_btc must be > 0, got {size_btc}")
+    if ttl_min <= 0:
+        raise ValueError(f"ttl_min must be > 0, got {ttl_min}")
+
+    s = snapshot.copy()
+    s.strategy_state = {
+        "type": "liquidity_harvester",
+        "center_price": s.close,
+        "side": side,
+        "offset_pct": offset_pct,
+        "width_pct": width_pct,
+        "target_pct": float(params.get("target_pct", 0.25)),
+        "gs_pct": float(params.get("gs_pct", 0.05)),
+        "size_btc": size_btc,
+        "ttl_min": ttl_min,
+    }
+    return s
+
+
+def action_close_all_and_restart(snapshot: Snapshot, params: dict) -> Snapshot:
+    """Close current position, lock profit if threshold met, then arm delayed restart grid."""
+    if snapshot.position_size_btc == 0:
+        return snapshot.copy()
+
+    pnl_threshold_pct = float(params["pnl_threshold_pct"])
+    offset_pct = float(params["offset_pct"])
+    restart_side = str(params["restart_side"])
+    if offset_pct <= 0:
+        raise ValueError("offset_pct must be > 0")
+    if restart_side not in {"same", "reverse"}:
+        raise ValueError(f"restart_side must be same/reverse, got {restart_side}")
+
+    s = snapshot.copy()
+    current_pnl_pct = (s.unrealized_pnl_usd / s.capital_usd * 100) if s.capital_usd else 0.0
+    if current_pnl_pct < pnl_threshold_pct:
+        return s
+
+    side_before = "short" if s.position_size_btc < 0 else "long"
+    side_after = side_before if restart_side == "same" else ("long" if side_before == "short" else "short")
+    close_fee = abs(s.position_size_btc) * s.close * 0.04 / 100
+
+    s.realized_pnl_session += s.unrealized_pnl_usd - close_fee
+    restart_size = abs(s.position_size_btc)
+    s.position_size_btc = 0.0
+    s.avg_entry = 0.0
+    s.unrealized_pnl_usd = 0.0
+    s.last_in_price = 0.0
+    s.bot_status = "running"
+    s.strategy_state = {
+        "type": "profit_lock_restart",
+        "side": side_after,
+        "entry_level": s.close * (1 + offset_pct / 100) if side_after == "short" else s.close * (1 - offset_pct / 100),
+        "offset_pct": offset_pct,
+        "size_btc": restart_size,
+        "target_pct": s.grid_target_pct,
+        "gs_pct": s.grid_step_pct,
+        "ttl_min": int(params.get("ttl_min", 240)),
+    }
+    return s
+
+
