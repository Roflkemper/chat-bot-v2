+
+
+def test_profit_lock_restart_entry_opens_position():
+    bars = _make_bars([(80_000, 81_000, 79_900, 80_700)])
+    snap = _snap(
+        close=80_000,
+        pos=0.0,
+        avg_entry=0.0,
+        strategy_state={
+            "type": "profit_lock_restart",
+            "side": "short",
+            "entry_level": 80_800,
+            "offset_pct": 1.0,
+            "size_btc": 0.18,
+            "target_pct": 1.0,
+            "gs_pct": 0.5,
+            "ttl_min": 5,
+        },
+    )
+    states = _run(snap, bars, slippage_pct=0.0, fees_maker_pct=0.0)
+    assert any(fill.order_type == "restart_entry" for fill in states[0].fills)
+    assert any(fill.order_type == "tp" for fill in states[0].fills)
+
+
+def test_profit_lock_restart_ttl_closes_open_position():
+    bars = _make_bars([
+        (80_000, 81_000, 79_900, 80_700),
+        (80_700, 80_900, 80_600, 80_800),
+    ])
+    snap = _snap(
+        close=80_000,
+        pos=0.0,
+        avg_entry=0.0,
+        strategy_state={
+            "type": "profit_lock_restart",
+            "side": "short",
+            "entry_level": 80_800,
+            "offset_pct": 1.0,
+            "size_btc": 0.18,
+            "target_pct": 5.0,
+            "gs_pct": 5.0,
+            "ttl_min": 2,
+        },
+    )
+    states = _run(snap, bars, slippage_pct=0.0, fees_maker_pct=0.0)
+    assert any(f.order_type == "restart_ttl" for s in states for f in s.fills)
+    assert states[-1].position_size_btc == pytest.approx(0.0)
+
+
+def test_profit_lock_restart_reverse_long_entry():
+    bars = _make_bars([(80_000, 80_100, 79_000, 79_300)])
+    snap = _snap(
+        close=80_000,
+        pos=0.0,
+        avg_entry=0.0,
+        strategy_state={
+            "type": "profit_lock_restart",
+            "side": "long",
+            "entry_level": 79_200,
+            "offset_pct": 1.0,
+            "size_btc": 0.18,
+            "target_pct": 1.0,
