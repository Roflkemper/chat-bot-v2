+            "ttl_min": 5,
+        },
+    )
+    states = _run(snap, bars, slippage_pct=0.0, fees_maker_pct=0.0)
+    assert any(fill.order_type == "restart_entry" for fill in states[0].fills)
+    assert any(fill.order_type == "tp" for fill in states[0].fills)
